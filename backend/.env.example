# ============================================================================
# Server Configuration
# ============================================================================
DEBUG=True
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ============================================================================
# Database Configuration (Phase 1: Repository Pattern)
# ============================================================================
# Database backend type: memory | sqlite | postgres
# Default: memory (for development)
DATABASE_TYPE=memory

# Connection URL (required for sqlite/postgres, ignored for memory):
# - SQLite:      sqlite:///weble.db  (creates file-based DB)
# - PostgreSQL:  postgresql+asyncpg://user:password@localhost:5432/weble
DATABASE_URL=

# Connection pool size (for sqlite/postgres)
DATABASE_POOL_SIZE=10

# ============================================================================
# File Storage Configuration
# ============================================================================
# Storage backend: local | s3
STORAGE_TYPE=local

# Local storage path for uploaded STEP files (relative or absolute)
LOCAL_STORAGE_PATH=./storage

# S3 Configuration (optional, for future phases)
# S3_BUCKET=
# S3_ENDPOINT=
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ============================================================================
# Processing Configuration
# ============================================================================
# Maximum file size for STEP upload (MB)
MAX_FILE_SIZE_MB=50

# Maximum number of parts per model
MAX_PARTS_PER_MODEL=500

# Processing timeouts (seconds)
STEP_PROCESSING_TIMEOUT_SECONDS=300      # 5 minutes for STEP file parsing
SVG_GENERATION_TIMEOUT_SECONDS=60        # 1 minute per SVG generation
ASSEMBLY_GENERATION_TIMEOUT_SECONDS=120  # 2 minutes for assembly analysis

# ============================================================================
# AI/LLM Configuration (for Phase 3: Assembly Instructions)
# ============================================================================
# OpenRouter API Key (required for Phase 3 AI assembly generation)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter API base URL (usually unchanged)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM Model selection
# Options: google/gemini-pro, anthropic/claude-2, etc.
LLM_MODEL=openai/gpt-4o-mini

# LLM timeout (seconds)
LLM_TIMEOUT_SECONDS=30

# ============================================================================
# Server-Sent Events (SSE) Configuration
# ============================================================================
# Progress update interval (seconds) - how often to send SSE updates
SSE_HEARTBEAT_SECONDS=2

# Job retention period (hours) - auto-cleanup jobs older than this
JOB_RETENTION_HOURS=24
