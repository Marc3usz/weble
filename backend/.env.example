# Database (currently using in-memory, will migrate to PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/weble_dev

# File Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage

# S3 (optional, for production)
# S3_BUCKET=weble-files
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# API Keys
OPENROUTER_API_KEY=sk_...your_key_here...

# Processing limits
MAX_FILE_SIZE_MB=50
MAX_PARTS_PER_MODEL=500

# LLM Configuration
LLM_TIMEOUT_SECONDS=30
LLM_MODEL=google/gemini-pro

# Server
DEBUG=True
LOG_LEVEL=INFO

# SSE
SSE_HEARTBEAT_SECONDS=5
